# Google Gemini API key (required for AI predictions)
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here

# football-data.org API key (optional — enables live fixtures, knockout bracket, real scores)
# Free tier covers World Cup 2026. Register at: https://www.football-data.org/client/register
# Without this key, the app falls back to the built-in static schedule.
VITE_FOOTBALL_API_KEY=your_football_data_key_here
